{
  "ConnectionStrings": {
    "CampanhasDb": "Host=localhost;Port=5432;Database=campanhas_db;Username=postgres;Password=postgres",
    "MongoDb": "mongodb://localhost:27017/transparencia_db"
  },
  "Jwt": {
    "SecretKey": "SuperSecretKey-ParaDesenvolvimento-MinimoDE32Chars!",
    "Issuer": "esperanca-identity-api",
    "Audience": "esperanca-platform"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}